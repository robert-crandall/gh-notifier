{
  "name": "gh-projects",
  "version": "0.1.0",
  "description": "Personal project management tool for developers",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src",
    "dist": "bun run build && electron-builder --mac",
    "dist:dir": "bun run build && electron-builder --dir --mac",
    "icons": "bash scripts/generate-icons.sh",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "setup": "bun install --ignore-scripts && bun run rebuild",
    "install-app": "bash scripts/install-app.sh"
  },
  "keywords": [],
  "author": "robert-crandall",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "daisyui": "^5.5.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.robertcrandall.gh-projects",
    "productName": "GH Projects",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "extraResources": [
      {
        "from": "db/migrations",
        "to": "db/migrations"
      }
    ],
    "files": [
      "out/**"
    ]
  }
}
