{
  "name": "gh-notifier",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src",
    "ci": "cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings && cd .. && bun run check && bun run lint",
    "tauri": "tauri",
    "install-app": "bash scripts/install.sh"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/parser": "^8.57.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "postcss": "^8.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-window-state": "^2.4.1"
  },
  "type": "module"
}
